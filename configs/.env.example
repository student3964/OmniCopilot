# =============================================================
# Omni Copilot — Environment Variables
# Copy this file to backend/.env and fill in your values
# =============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/omni_copilot
# For Supabase: postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── LLM Providers ─────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Primary LLM provider: groq | openai | gemini
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile   # Groq model
# LLM_MODEL=gpt-4.1                 # OpenAI model
# LLM_MODEL=gemini-2.0-flash        # Gemini model

# ── Google OAuth 2.0 ──────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Required Google OAuth scopes (space-separated):
# https://www.googleapis.com/auth/drive.readonly
# https://www.googleapis.com/auth/gmail.modify
# https://www.googleapis.com/auth/calendar
# https://www.googleapis.com/auth/documents.readonly

# ── Slack OAuth ───────────────────────────────────────────────
# Create at https://api.slack.com/apps
SLACK_CLIENT_ID=xxxxxxxxxxxx.xxxxxxxxxxxx
SLACK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_REDIRECT_URI=http://localhost:8000/api/auth/slack/callback
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Notion OAuth ──────────────────────────────────────────────
# Create at https://www.notion.so/my-integrations
NOTION_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_CLIENT_SECRET=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_REDIRECT_URI=http://localhost:8000/api/auth/notion/callback

# ── Zoom OAuth ────────────────────────────────────────────────
# Create at https://marketplace.zoom.us/develop/create
ZOOM_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
ZOOM_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZOOM_REDIRECT_URI=http://localhost:8000/api/auth/zoom/callback

# ── App Config ────────────────────────────────────────────────
APP_NAME=Omni Copilot
APP_VERSION=1.0.0
DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/omni_copilot.log
